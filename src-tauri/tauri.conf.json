{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "quickboard",
  "version": "0.1.0",
  "identifier": "tech.treshnanda.quickboard",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "quickboard",
        "width": 800,
        "height": 600,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "visible": false
      },
      {
        "label": "summon",
        "url": "panel.html",
        "title": "Summon",
        "width": 700,
        "height": 540,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "resizable": false,
        "shadow": false
      },
      {
        "label": "tray",
        "url": "tray.html",
        "title": "Tray",
        "width": 340,
        "height": 392,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "resizable": false,
        "shadow": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "Save anything, summon it to your cursor in seconds.",
    "longDescription": "quickboard keeps your notes, links, files, and snippets a keystroke away. Press Option-Space to summon a launcher over any app and drop what you need right at your cursor — no window-switching, no digging.",
    "copyright": "Copyright © 2026 Treshnanda. All rights reserved.",
    "resources": ["Assets.car"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
