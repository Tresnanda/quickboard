{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main + summon + tray windows",
  "windows": ["main", "summon", "tray"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-start-dragging",
    "opener:default",
    "drag:default",
    "dialog:default",
    "updater:default"
  ]
}
